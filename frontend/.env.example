# ──────────────────────────────────────────────────────────────────────────────
# SkillProof Frontend — Environment Variables
# Copy this file to .env and fill in your values before starting the app.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── API Configuration ─────────────────────────────────────────────────────────
# Development: Use localhost with your backend port (no /api suffix)
# Production: Use your deployed backend URL (e.g., https://skillproof-25.onrender.com)
VITE_API_URL=http://localhost:5001

# ── App Configuration ─────────────────────────────────────────────────────────
VITE_APP_NAME=SkillProof
VITE_APP_VERSION=1.0.0
